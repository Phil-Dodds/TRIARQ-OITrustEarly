# initiative-public-mcp — environment (Contract 31, D-473)
# Set these as Render secrets. NEVER commit a real .env (Arch-4).

# Shared with the other MCP servers — service role key (bypasses RLS; internal only).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Port Render binds. Render injects PORT automatically; INITIATIVE_MCP_PORT is a
# local-dev fallback. (No RENDER_INTERNAL_API_KEY — this server authenticates via
# API key, not internal Render auth.)
INITIATIVE_MCP_PORT=3004
