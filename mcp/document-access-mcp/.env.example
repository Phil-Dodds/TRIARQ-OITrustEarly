# document-access-mcp environment variables
# Copy to .env for local development. Never commit .env.
# Set these as Render Environment Variables for deployment.

# Supabase — both values from Dashboard > Project Settings > API
SUPABASE_URL=https://dpnkxrrtqfqkhuzbljbw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=          # service_role key (keep secret)

# ClamAV daemon — TCP connection for malware scanning (Layer 2, D-146)
# Local dev: docker run -d -p 3310:3310 clamav/clamav:stable
# Render:     set CLAMAV_HOST to the internal hostname of your ClamAV service
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=30000

# Server
PORT=3002
