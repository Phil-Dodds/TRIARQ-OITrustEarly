# delivery-cycle-mcp environment variables
# Copy to .env for local development. Never commit .env.
# Set these as Render Environment Variables for deployment.

# Supabase — both values from Dashboard > Project Settings > API
SUPABASE_URL=https://dpnkxrrtqfqkhuzbljbw.supabase.co
SUPABASE_SERVICE_ROLE_KEY=          # service_role key (keep secret — never expose to Angular)

# JWT validation uses supabase.auth.getUser() internally — no JWT secret or Key ID needed.

# Dev bypass — set to enable devbypass::<token>::<email> auth in local/staging
# Remove from Render environment to disable entirely in production.
# DEV_BYPASS_TOKEN=

# Jira Integration (required for sync_jira_epic tool)
# If not set, sync_jira_epic returns a graceful stub response.
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_API_TOKEN=
# JIRA_USER_EMAIL=

# Server
PORT=3003
